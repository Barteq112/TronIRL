@page "/addgame"
@using Tron.Server.Services
@rendermode InteractiveServer

<PageTitle>Dodaj Grę - TRON</PageTitle>

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Parametry Gry</h5>
                </div>
                <div class="card-body">
                    <EditForm Model="@newGameModel" OnValidSubmit="HandleAddGame">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label>Nazwa Gry:</label>
                            <InputText class="form-control" @bind-Value="newGameModel.Name" />
                        </div>
                        <div class="mb-3">
                            <label>Max Graczy:</label>
                            <InputNumber class="form-control" @bind-Value="newGameModel.MaxPlayers" />
                        </div>

                        <hr />
                        <h6>🌍 Lokalizacja i Rozmiar</h6>
                        <p class="text-muted small">
                            Zmień wartości poniżej, aby przesunąć mapę, LUB przesuń czerwony prostokąt na mapie.
                        </p>

                        <div class="row">
                            <div class="col-6 mb-2">
                                <label class="small">Szer. Geog. (Lat)</label>
                                <InputNumber class="form-control form-control-sm"
                                             @bind-Value="newGameModel.CenterLat"
                                             @bind-Value:after="SyncMapFromInputs"
                                             step="0.0001" />
                            </div>
                            <div class="col-6 mb-2">
                                <label class="small">Dł. Geog. (Lon)</label>
                                <InputNumber class="form-control form-control-sm"
                                             @bind-Value="newGameModel.CenterLon"
                                             @bind-Value:after="SyncMapFromInputs"
                                             step="0.0001" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="small">Szerokość (m)</label>
                                <InputNumber class="form-control form-control-sm"
                                             @bind-Value="newGameModel.WidthMeters"
                                             @bind-Value:after="SyncMapFromInputs"
                                             step="0.0001" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="small">Wysokość (m)</label>
                                <InputNumber class="form-control form-control-sm"
                                             @bind-Value="newGameModel.HeightMeters"
                                             @bind-Value:after="SyncMapFromInputs"
                                             step="0.0001" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success w-100">Utwórz Grę</button>
                    </EditForm>
                </div>
            </div>

            <div class="card">
                <div class="card-header">Aktywne Gry</div>
                <ul class="list-group list-group-flush">
                    @foreach (var g in GameManager.Games.Values)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="small">@g.Info.Name (@g.Info.CurrentPlayers os.)</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-8">
            <div id="map" style="height: 85vh; width: 100%; border-radius: 8px; border: 2px solid #ccc;"></div>
        </div>
    </div>
</div>