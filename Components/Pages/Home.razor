@page "/"
@using Tron.Server.Services
@inject GameManager GameManager
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Panel Admina - TRON</PageTitle>

<div class="container py-5">

    <div class="p-5 mb-5 bg-light rounded-3 shadow-sm text-center border">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold text-dark">Serwer Gry TRON</h1>
            <p class="col-md-8 fs-5 text-muted mx-auto">
                Panel zarządzania rozgrywką terenową. Tutaj możesz tworzyć nowe areny, monitorować aktywność graczy i zarządzać statusem serwera.
            </p>
            <div class="mt-4">
                <a href="addgame" class="btn btn-primary btn-lg px-4 gap-3 shadow-sm">
                    <i class="bi bi-plus-lg me-2"></i> Utwórz nową grę
                </a>
                <button class="btn btn-outline-secondary btn-lg px-4" @onclick="RefreshStats">
                    <i class="bi bi-arrow-clockwise me-2"></i> Odśwież
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3 text-primary">
                        <i class="bi bi-controller fs-3"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle text-muted mb-1">Aktywne Gry</h6>
                        <h2 class="card-title mb-0 fw-bold">@ActiveGamesCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3 text-success">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle text-muted mb-1">Podłączeni Gracze</h6>
                        <h2 class="card-title mb-0 fw-bold">@TotalPlayersCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="bg-info bg-opacity-10 p-3 rounded-circle me-3 text-info">
                        <i class="bi bi-router fs-3"></i>
                    </div>
                    <div style="overflow: hidden;">
                        <h6 class="card-subtitle text-muted mb-1">Adres IP Serwera</h6>
                        <h2 class="card-title mb-0 fw-bold fs-4 text-truncate">@ServerIp</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center text-muted small mt-5">
        <hr />
        <p>System działa poprawnie. Ostatnia aktualizacja danych: @DateTime.Now.ToString("HH:mm:ss")</p>
    </div>
</div>

@code {
    private System.Threading.Timer? timer;
    private string ServerIp = "127.0.0.1";

    private int ActiveGamesCount => GameManager.Games.Count;
    private int TotalPlayersCount => GameManager.Games.Values.Sum(g => g.Info.CurrentPlayers);

    protected override void OnInitialized()
    {
        GetLocalIpAddress();

        // Odświeżanie co 2 sekundy (wystarczy, nie musi być co sekundę)
        timer = new System.Threading.Timer((_) => InvokeAsync(StateHasChanged), null, 0, 2000);
    }

    private void RefreshStats()
    {
        StateHasChanged();
    }

    private void GetLocalIpAddress()
    {
        try
        {
            var host = System.Net.Dns.GetHostEntry(System.Net.Dns.GetHostName());
            var ip = host.AddressList.FirstOrDefault(x => x.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork);
            ServerIp = ip?.ToString() ?? "localhost";
        }
        catch
        {
            ServerIp = "Nieznane";
        }
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}